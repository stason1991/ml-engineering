#3. Блок ML-модели (Алгоритмы и Конфигурация)
class Centroid:
    """Сущность-эталон бизнес-направления (Направление развития)"""
    def __init__(self, name: str, coordinates: List[float]):
        self._name = name
        self._coordinates = coordinates

class MLModel:
    """Интерфейс для ML-моделей, отсюда можем расширяться на разные ml-модели"""
    def predict(self, data_vector: List[float], centroids: List[Centroid]) -> 	str:
        raise NotImplementedError

class EuclideanKMeansModel(MLModel):
